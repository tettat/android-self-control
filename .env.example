# Copy this file to .env and fill in the values you want to inject at build time.

# OpenAI-compatible API defaults used by the app when the user has not saved values yet.
DEFAULT_API_ENDPOINT=https://api.openai.com/v1
DEFAULT_API_KEY=

# Optional default pairing relay URL shown in the app settings.
DEFAULT_RELAY_URL=

# Optional comma-separated hostnames/IPs that are allowed for cleartext HTTP traffic.
# Example: CLEARTEXT_DOMAINS=192.168.1.10,relay.local
CLEARTEXT_DOMAINS=
